{
  "name": "github-actions-tag-sha-verifier",
  "description": "Verifies the if the SHA of the referenced tags have changed across the time.",
  "version": "0.0.1",
  "author": "Mustapha Belmokhtar",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/BelmoMusta/github-actions-tag-sha-verifier",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BelmoMusta/github-actions-tag-sha-verifier.git"
  },
  "bugs": {
    "url": "https://github.com/BelmoMusta/github-actions-tag-sha-verifier/issues"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write \"**/*.ts\"",
    "format:check": "npx prettier --check \"**/*.ts\"",
    "local-action": "npx local-action . src/main.ts .env",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "index.ts"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ]
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "fs-extra": "^11.3.4",
    "octokit": "^5.0.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.4",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.2",
    "rollup": "^4.57.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
